/* Global styles for the Regex Simulator */

:root {
  /* Dark theme variables */
  --bg-primary: #242424;
  --bg-secondary: #1a1a1a;
  --bg-tertiary: #2a2a2a;
  --bg-input: #333;
  --text-primary: #ffffff;
  --text-secondary: #e0e0e0;
  --text-accent: #b3e5fc;
  --accent-color: #61dafb;
  --accent-hover: #21b4d6;
  --border-color: #555;
  --shadow-color: rgba(0, 0, 0, 0.3);
  --error-color: #ff6b6b;
  --success-color: #4caf50;
  --danger-color: #f44336;
}

/* Light theme variables */
body.light {
  --bg-primary: #f5f5f5;
  --bg-secondary: #ffffff;
  --bg-tertiary: #f8f8f8;
  --bg-input: #ffffff;
  --text-primary: #1a1a1a;
  --text-secondary: #666666;
  --text-accent: #1976d2;
  --accent-color: #2196f3;
  --accent-hover: #1976d2;
  --border-color: #ddd;
  --shadow-color: rgba(0, 0, 0, 0.1);
  --error-color: #f44336;
  --success-color: #4caf50;
  --danger-color: #f44336;
}
.theme-toggle {
  background: var(--bg-tertiary);
  border: 1px solid var(--border-color);
  color: var(--text-primary);
  padding: 8px 10px;
  border-radius: 8px;
  cursor: pointer;
  font-size: 18px;
  transition: all 0.2s ease;
}

.theme-toggle:hover {
  background: var(--accent-color);
  color: var(--bg-secondary);
}
* {
  box-sizing: border-box;
}

body {
  margin: 0;
  padding: 0;
  font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
  background-color: var(--bg-primary);
  color: var(--text-primary);
  transition: background-color 0.3s, color 0.3s;
}

#root {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* Navbar Styles */
nav {
  background-color: var(--bg-secondary);
  border-bottom: 2px solid var(--accent-color);
  padding: 10px 20px;
  display: flex;
  gap: 20px;
  box-shadow: 0 2px 8px var(--shadow-color);
  position: sticky;
  top: 0;
  z-index: 100;
  justify-content: space-between;
  align-items: center;
  min-height: 50px;
}

.nav-link {
  color: var(--text-primary);
  text-decoration: none;
  font-size: 1.1em;
  padding: 8px 16px;
  border-radius: 5px;
  transition: background-color 0.3s, color 0.3s;
  position: relative;
}

.nav-link:hover {
  background-color: var(--accent-color);
  color: var(--bg-secondary);
}

.nav-link.active {
  color: var(--accent-color);
  font-weight: 600;
}

.nav-link.active::after {
  content: '';
  position: absolute;
  bottom: -8px;
  left: 50%;
  transform: translateX(-50%);
  width: 20px;
  height: 2px;
  background-color: var(--accent-color);
  border-radius: 1px;
}


/* Page Container Wrapper */
main,
div > div > div > div {
  flex: 1;
  background-color: var(--bg-primary);
  color: var(--text-primary);
  padding: 30px 20px;
}

/* Page content container */
div:has(> h1) {
  max-width: 900px;
  margin: 0 auto;
}

h1 {
  text-align: center;
  margin-bottom: 30px;
  font-size: 2.5em;
  color: var(--accent-color);
}

h2 {
  margin-top: 25px;
  margin-bottom: 15px;
  font-size: 1.5em;
  color: var(--text-primary);
}

h3 {
  color: var(--text-accent);
  font-size: 1.2em;
}

/* Section styles */
.section {
  margin-bottom: 30px;
  padding: 20px;
  background-color: var(--bg-tertiary);
  border-radius: 8px;
  box-shadow: 0 2px 4px var(--shadow-color);
}

.section h2 {
  margin-top: 0;
  margin-bottom: 15px;
}

.input-group {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

/* Input styles */
input[type="text"] {
  padding: 12px;
  font-size: 1em;
  border: 1px solid var(--border-color);
  border-radius: 5px;
  background-color: var(--bg-input);
  color: var(--text-primary);
  transition: border-color 0.3s, box-shadow 0.3s;
}

input[type="text"]:focus {
  outline: none;
  border-color: var(--accent-color);
  box-shadow: 0 0 5px rgba(97, 218, 251, 0.5);
}

input[type="text"]::placeholder {
  color: var(--text-secondary);
}

/* Button styles */
button {
  padding: 12px 24px;
  font-size: 1em;
  background-color: var(--accent-color);
  color: var(--bg-secondary);
  border: none;
  border-radius: 5px;
  cursor: pointer;
  transition: background-color 0.3s, transform 0.2s;
  font-weight: 500;
}

button:hover {
  background-color: var(--accent-hover);
  transform: translateY(-2px);
}

button:active {
  transform: translateY(0);
}

/* Results list styles */
.results-list {
  list-style-type: none;
  padding: 0;
  margin: 0;
}

.results-list li {
  padding: 10px;
  margin-bottom: 5px;
  background-color: var(--bg-input);
  border-radius: 5px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-left: 5px solid var(--text-secondary);
  transition: background-color 0.2s;
}

.results-list li.accepted {
  border-left-color: var(--success-color);
  background-color: rgba(76, 175, 80, 0.1);
}

.results-list li.rejected {
  border-left-color: var(--danger-color);
  background-color: rgba(244, 67, 54, 0.1);
}

.results-list li:hover {
  background-color: var(--bg-tertiary);
}

/* Results header with clear button */
.results-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15px;
}

.results-header h2 {
  margin: 0;
}

.btn-clear {
  padding: 8px 16px;
  font-size: 0.9em;
  background-color: #f44336;
  color: #ffffff;
  border: none;
  border-radius: 5px;
  cursor: pointer;
  transition: background-color 0.3s, transform 0.2s;
}

.btn-clear:hover {
  background-color: #da190b;
  transform: translateY(-2px);
}

.no-results {
  text-align: center;
  color: #999;
  padding: 20px;
  font-style: italic;
}

/* Error message styles */
p[style*="color: red"] {
  color: #ff6b6b !important;
  padding: 12px;
  background-color: rgba(255, 107, 107, 0.1);
  border-radius: 5px;
  border-left: 4px solid #ff6b6b;
  margin: 20px 0;
}

/* Pre/Code block styles */
pre {
  background-color: #1a1a1a;
  padding: 15px;
  border-radius: 5px;
  overflow-x: auto;
  font-size: 0.95em;
  border-left: 4px solid #61dafb;
  color: #b3e5fc;
}

/* List styles */
ul,
ol {
  padding-left: 20px;
}

ul li,
ol li {
  margin-bottom: 8px;
  line-height: 1.6;
}

/* Paragraph styles */
p {
  line-height: 1.6;
  color: #e0e0e0;
  margin-bottom: 15px;
}

/* Responsive design */
@media (max-width: 768px) {
  main,
  div > div > div > div {
    padding: 20px 15px;
  }

  nav {
    flex-wrap: wrap;
    gap: 10px;
    padding: 8px 15px;
    min-height: 45px;
  }

  .nav-link {
    font-size: 0.95em;
    padding: 6px 12px;
  }

  .nav-link.active::after {
    bottom: -6px;
    width: 15px;
  }

  h1 {
    font-size: 2em;
    margin-bottom: 20px;
  }

  h2 {
    font-size: 1.3em;
  }

  .section {
    padding: 15px;
    margin-bottom: 20px;
  }

  input[type="text"],
  button {
    font-size: 0.95em;
  }

  .results-list li {
    flex-direction: column;
    align-items: flex-start;
    gap: 8px;
  }

  .results-list li span:last-child {
    align-self: flex-end;
  }

  pre {
    font-size: 0.85em;
    padding: 10px;
  }

  .results-header {
    flex-direction: column;
    align-items: flex-start;
    gap: 10px;
  }

  .btn-clear {
    width: 100%;
  }
}

@media (max-width: 480px) {
  h1 {
    font-size: 1.8em;
  }

  h2 {
    font-size: 1.2em;
  }

  nav {
    gap: 8px;
    padding: 6px 12px;
  }

  .nav-link {
    font-size: 0.85em;
    padding: 5px 10px;
  }

  .nav-link.active::after {
    width: 12px;
  }

  button {
    width: 100%;
  }

  .section {
    padding: 12px;
  }
}

